# Redis connection string. For local dev: redis://localhost:6379
# For Fly.io: set this to the internal Redis URL from fly secrets
REDIS_URL=redis://localhost:6379

# Seconds between nba_api play-by-play polls.
# 3s gives comfortable headroom within nba_api rate limits (~1 req/sec)
# while keeping latency acceptable for a stats application.
NBA_API_DELAY=3
